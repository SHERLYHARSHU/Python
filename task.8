def subarray_with_given_sum(arr, target):
    n = len(arr)

    for i in range(n):
        curr_sum = 0

        for j in range(i, n):
            curr_sum += arr[j]

            if curr_sum == target:
                return arr[i:j + 1]
    return []
arr = [1, 2, 3]
target = 5
print(subarray_with_given_sum(arr, target))
