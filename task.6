def min_sum_subarray(arr):
    current_sum = arr[0]
    min_sum = arr[0]
    for i in range(1, len(arr)):
        if current_sum > 0:
            current_sum = arr[i]
        else:
            current_sum += arr[i]
        if current_sum < min_sum:
            min_sum = current_sum
    return min_sum
